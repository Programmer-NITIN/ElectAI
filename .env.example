# ── ElectAI Environment Variables ──────────────────────────────────────
# Copy this file to .env.local and fill in your values.
# Variables prefixed with NEXT_PUBLIC_ are exposed to the browser.

# ── Google AI (Required for AI features) ───────────────────────────────
# Get your key: https://aistudio.google.com/apikey
GOOGLE_GENERATIVE_AI_API_KEY=

# ── Google Vertex AI (Production — optional) ───────────────────────────
GOOGLE_VERTEX_PROJECT=
GOOGLE_VERTEX_LOCATION=asia-south1
GOOGLE_SERVICE_ACCOUNT_KEY=

# ── Firebase (Optional — analytics, auth, feedback storage) ────────────
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# ── Google Maps (Optional — polling booth locator) ─────────────────────
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# ── Google reCAPTCHA (Optional — bot protection) ───────────────────────
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=

# ── Google Analytics (Optional) ────────────────────────────────────────
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# ── Google Cloud Services (Optional — TTS, Translation, Vision) ────────
GOOGLE_APPLICATION_CREDENTIALS=
GOOGLE_CLOUD_PROJECT=
